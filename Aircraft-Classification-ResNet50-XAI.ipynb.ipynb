    "1. Loading the Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "06a80cd6-1793-4210-b213-f41692366128",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
