   "source": [
    "2. Setting up ResNet-50"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "40a8846b-329a-4fec-8d2a-98efa690d2e7",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Step 2 Complete: Strict model is built and ready on the GPU.\n"
     ]
    }
   ],
   "source": [
    "# 1. Load a fresh ResNet-50\n",
    "model = models.resnet50(weights='IMAGENET1K_V1')\n",
    "num_features = model.fc.in_features\n",
    "\n",
    "# 2. Add the \"Blindfold\" (Dropout) to prevent memorization\n",
    "model.fc = nn.Sequential(\n",
    "    nn.Dropout(p=0.5), \n",
    "    nn.Linear(num_features, 100)\n",
    ")\n",
    "model = model.to(device)\n",
    "\n",
    "# 3. Setup the Scorekeeper and the Pilot\n",
    "criterion = nn.CrossEntropyLoss()\n",
    "\n",
    "# 4. Add the \"Weight Penalty\" (weight_decay) to stop cheating\n",
    "optimizer = optim.Adam(model.parameters(), lr=0.0001, weight_decay=1e-4)\n",
    "\n",
    "# 5. The Navigator\n",
    "scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode='max', factor=0.5, patience=5)\n",
    "\n",
    "print(\"Step 2 Complete: Strict model is built and ready on the GPU.\")"
   ]
  },
